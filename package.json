{
  "name": "nexus-mesh",
  "author": "Nexus Team",
  "homepage": "https://github.com/nexus/mesh",
  "version": "1.0.0",
  "description": "P2P Collaboration Hub",
  "main": "electron-main.js",
  "scripts": {
    "start": "electron .",
    "start:electron": "electron .",
    "build:win": "electron-builder --win",
    "android:init": "cap init nexus-mesh com.nexus.mesh --web-dir www",
    "android:add": "cap add android",
    "android:sync": "cap sync android"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "@capacitor/cli": "^5.0.0",
    "@capacitor/core": "^5.0.0",
    "@capacitor/android": "^5.0.0"
  },
  "build": {
    "appId": "com.nexus.mesh",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "files": [
      "www/**/*",
      "electron-main.js"
    ]
  }
}
